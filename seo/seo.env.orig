# Shared settings for all OpenAI pipelines.
# Copy to seo.env and fill in API_KEY — never commit seo.env.
#
# Pipeline-specific .env files load this first; any key here can be
# overridden in the pipeline file or by a system environment variable.

# --- API (OpenAI-compatible — used by write_articles, review_articles, etc.)
API_KEY=your_openai_key_here
MODEL=gpt-4.1-mini
API_URL=https://api.openai.com/v1/chat/completions

# --- Anthropic (used by guided_fix only)
ANTHROPIC_API_KEY=your_anthropic_key_here

# --- Resilience (applies to all pipelines unless overridden)
MAX_RETRIES=3
CONTINUE_ON_ERROR=true
MAX_CONSECUTIVE_FAILURES=5
