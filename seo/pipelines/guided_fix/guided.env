# guided_fix — interactive AI-driven walkthrough of audit todo items.
# API_KEY, MODEL, API_URL come from ../../seo.env (shared with other pipelines).

DATA_ROOT=../../data

# Override the default model just for guided_fix (otherwise inherits MODEL from seo.env).
# GUIDED_MODEL=gpt-4.1-mini

# Cost caps (USD). Defaults match gpt-4.1-mini at typical session length.
MAX_COST_USD_PER_SESSION=5.00
MAX_COST_USD_PER_ITEM=1.00

# Pricing for cost tracking. Update when changing model.
# gpt-4.1-mini: 0.40 / 1.60 (Apr 2026). Claude Sonnet 4.6 ref: 3.00 / 15.00.
INPUT_PRICE_PER_MTOK=0.40
OUTPUT_PRICE_PER_MTOK=1.60

# Hard cap on AI turns within a single item (prevents runaway loops).
MAX_TURNS_PER_ITEM=30

# SITE-SPECIFIC: shown in the AI's context.
SITE_URL=https://hybridautopart.com

# To walk only one issue type, set ITEM in the shell before `make run`:
#   ITEM=canonical_cross_language make run
