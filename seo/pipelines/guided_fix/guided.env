# guided_fix — interactive AI-driven walkthrough of audit todo items.
# ANTHROPIC_API_KEY should live in ../../seo.env (shared secret).

DATA_ROOT=../../data

# Claude model used for the conversation. Pricing constants in main.py
# assume Sonnet 4.6; update both if you switch model.
GUIDED_MODEL=claude-sonnet-4-6

# Cost caps (USD).
MAX_COST_USD_PER_SESSION=5.00
MAX_COST_USD_PER_ITEM=1.00

# Hard cap on AI turns within a single item (prevents runaway loops).
MAX_TURNS_PER_ITEM=30

# SITE-SPECIFIC: shown in the AI's context.
SITE_URL=https://hybridautopart.com

# To walk only one issue type, set ITEM in the shell before `make run`:
#   ITEM=canonical_cross_language make run
