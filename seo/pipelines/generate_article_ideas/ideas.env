# generate_article_ideas — pipeline-specific settings.
# Shared keys (API_KEY, MODEL, API_URL, MAX_RETRIES, etc.) come from ../../seo.env.

INPUT_DIR=input
OUTPUT_DIR=output

# --- AI mode
USE_AI=false
MAX_TOKENS=4096
IDEAS_PER_SEED=8
BATCH_SIZE=10

# --- Algorithmic mode (used when USE_AI=false)
USE_AUTOCOMPLETE=true
AUTOCOMPLETE_AZ=true
AUTOCOMPLETE_MODIFIERS=true
USE_PATTERNS=true

# Timings (lower than other pipelines — autocomplete calls, not LLM)
DELAY_MS=500
JITTER_MS=300
TIMEOUT=10

DEFAULT_WORD_COUNT=1200
