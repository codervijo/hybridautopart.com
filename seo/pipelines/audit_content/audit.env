# audit_content — pure transform over the latest crawl snapshot.

DATA_ROOT=../../data

# Thin-page threshold: pages with fewer than this many words flagged.
THIN_WORDS=800

# Near-duplicate cosine similarity threshold (0.0–1.0). 0.75 is a reasonable
# balance for ~1500-word articles — catches genuine overlap, ignores topical proximity.
DUP_THRESHOLD=0.75
