# crawl_site — site crawl settings.
# Shared keys (if any) come from ../../seo.env.

# SITE-SPECIFIC: target site
SITE_URL=https://hybridautopart.com
SITEMAP_URL=https://hybridautopart.com/sitemap_index.xml

# Identify as a bot. URL contact in UA per RFC convention.
USER_AGENT=hybridautopart-seo-bot/0.1 (+https://hybridautopart.com)

# Polite crawl: ~0.5s between requests with up to 0.2s jitter.
DELAY_MS=500
JITTER_MS=200
TIMEOUT=30

# Where dated snapshots land (relative to this pipeline dir).
DATA_ROOT=../../data
OUTPUT_DIR=output
