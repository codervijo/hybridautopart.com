# generate_images — pipeline-specific settings.
# Shared keys (MAX_RETRIES, CONTINUE_ON_ERROR, etc.) come from ../../seo.env.
# Note: uses IMAGE_API_KEY / IMAGE_API_URL / IMAGE_MODEL, not the shared API_KEY.

INPUT_DIR=input
OUTPUT_DIR=output/posts

USE_IMAGE_AI=false
IMAGE_API_KEY=your_key_here
IMAGE_API_URL=https://api.openai.com/v1/images/generations
IMAGE_MODEL=dall-e-3
IMAGE_SIZE=1792x1024

TIMEOUT=60
DELAY_MS=2000
JITTER_MS=500
